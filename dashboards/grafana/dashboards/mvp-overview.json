        {"expr": "eval_metric_value{metric_name=\"relevance\"}", "legendFormat": "eval relevance"}
      ],
      "title": "Retrieval Quality",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 18},
