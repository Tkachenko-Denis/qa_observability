    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 4},
      "id": 5,
      "targets": [
        {"expr": "sum by (endpoint, status) (rate(http_requests_total[5m]))", "legendFormat": "{{endpoint}} {{status}}"},
        {"expr": "sum by (endpoint) (rate(http_errors_total[5m]))", "legendFormat": "{{endpoint}} errors"}
      ],
      "title": "API Requests And Errors",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 4},
      "id": 6,
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "api p95"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(llm_latency_seconds_bucket[5m])))", "legendFormat": "llm p95"},
        {"expr": "histogram_quantile(0.95, sum by (le) (rate(retrieval_latency_seconds_bucket[5m])))", "legendFormat": "retrieval p95"}
      ],
      "title": "Latency P95",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 11},
      "id": 7,
      "targets": [
        {"expr": "rate(llm_input_tokens_total[5m])", "legendFormat": "input tokens/s"},
        {"expr": "rate(llm_output_tokens_total[5m])", "legendFormat": "output tokens/s"},
        {"expr": "rate(llm_errors_total[5m])", "legendFormat": "llm errors/s"}
      ],
      "title": "LLM Tokens And Errors",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 11},
      "id": 8,
      "targets": [
        {"expr": "rate(retrieval_empty_results_total[5m])", "legendFormat": "empty retrieval/s"},
