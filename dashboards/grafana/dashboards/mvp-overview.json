      "title": "LLM Eval Scores",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 18},
      "id": 10,
      "targets": [
        {"expr": "dq_run_status", "legendFormat": "{{category}} {{status}}"},
        {"expr": "dq_checks_failed_total", "legendFormat": "failed {{category}}"}
