      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 7, "w": 12, "x": 0, "y": 25},
      "id": 11,
      "targets": [
        {"expr": "dq_missing_ratio or dq_duplicate_ratio or dq_schema_validity_ratio or dq_completeness_ratio", "legendFormat": "{{__name__}} {{dataset}}"},
