APP_NAME=llmops-dq-observability
APP_ENV=local
APP_HOST=0.0.0.0
APP_PORT=8000
UI_BACKEND_URL=http://localhost:8000
UI_PROMETHEUS_URL=http://localhost:9090
UI_REQUEST_TIMEOUT_SECONDS=30
LOG_LEVEL=INFO
API_KEY=change-me
API_KEY_AUTH_ENABLED=false
STORE_RAW_INPUT=false
STORE_RAW_OUTPUT=false
DATABASE_URL=postgresql+psycopg://dq:dq@localhost:5432/dq_observability
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=rag_chunks
MILVUS_ENABLED=false
LLM_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
LOCAL_LLM_BASE_URL=http://host.docker.internal:11434
LOCAL_LLM_MODEL=llama3
QWEN_OLLAMA_MODEL=qwen2.5:7b
QWEN_OLLAMA_3B_MODEL=qwen2.5:3b
QWEN_OLLAMA_7B_MODEL=qwen2.5:7b
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_ENABLED=false
PROMETHEUS_NAMESPACE=dq
PROMETHEUS_MULTIPROC_DIR=/tmp/prometheus
DEFAULT_DATA_CONTOUR=rag_documents
DEFAULT_BASELINE_STRATEGY=previous_version
HARD_GATE_ENABLED=true
SOFT_GATE_ENABLED=true
QUALITY_GATE_RESPONSE_WINDOW=50
LLM_JUDGE_ENABLED=false
LLM_ALLOW_MOCK_FALLBACK=true
DEFAULT_MODEL_PROFILE_ID=mock
MODEL_PROFILE_QWEN_OLLAMA_ENABLED=true
MODEL_PROFILE_OLLAMA_LLAMA_ENABLED=false
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_ENABLED=false
DEFAULT_RAG_DATASET_PATH=datasets/samples/rag_documents_extended_v2.jsonl
DEFAULT_RAG_DATASET_VERSION=sample-v2
RAG_TOP_K=5
RAG_MIN_RETRIEVAL_SCORE=0.0
QUALITY_THRESHOLDS_PATH=config/quality_thresholds.yaml
AIRFLOW_API_BASE_URL=http://localhost:8080
AIRFLOW_USERNAME=admin
AIRFLOW_PASSWORD=admin
AIRFLOW_API_TIMEOUT_SECONDS=10
AIRFLOW_API_RETRIES=5
AIRFLOW_API_RETRY_DELAY_SECONDS=2
